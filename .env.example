# ─────────────────────────────────────────────
# LG Promo Banner Tool — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Claude API (required for live classification + copy generation)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ideogram API (for AI background generation)
# Get key at: https://ideogram.ai/
IDEOGRAM_API_KEY=

# Midjourney API — alternative to Ideogram (optional)
MIDJOURNEY_API_KEY=

# Figma integration (for direct-to-Figma export)
# Token: https://www.figma.com/settings → Personal Access Tokens
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_ID=

# Optional: Cloudflare R2 or AWS S3 for storing exports
# EXPORT_STORAGE_BUCKET=
# EXPORT_STORAGE_REGION=
# EXPORT_STORAGE_KEY=
# EXPORT_STORAGE_SECRET=
